    <worksheet name='Top 10 - insurer'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Top 10 expensive procedures - Insurer Price vs. Discounted Cash</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Project_Data' name='federated.1lzqd641yvgrh7183uk5c18yqpxo' />
          </datasources>
          <datasource-dependencies datasource='federated.1lzqd641yvgrh7183uk5c18yqpxo'>
            <column caption='Billing Codes' datatype='integer' name='[Billing Code (copy)_5292011042807881729]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[billing_code]' />
            </column>
            <column caption='Billing Code 5 digits' datatype='boolean' name='[Calculation_1080300962865369088]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN(STR([billing_code])) = 5' />
            </column>
            <column caption='DC&lt;IP' datatype='string' name='[Calculation_442549038454980611]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF ATTR([metroplex]) = &quot;NYC&quot; AND &#10;   [Calculation_442549038455279621] &lt; [Calculation_442549038455218180]&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Normal&quot;&#10;END' />
            </column>
            <column caption='Max IP' datatype='real' name='[Calculation_442549038455218180]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MAX([insurer_price])' />
            </column>
            <column caption='Max DC' datatype='real' name='[Calculation_442549038455279621]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MAX([discounted_cash])' />
            </column>
            <column caption='Top 10 expensive - insurer price' datatype='string' name='[Calculation_5292011042807595008]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Billing Code (copy)_5292011042807881729]&#10;  WHEN 42100 THEN &quot;Biopsy of the palate or uvula&quot;&#10;  WHEN 33249 THEN &quot;Implantable Defibrillator Procedures&quot;&#10;  WHEN 90288 THEN &quot;Botulism immune globulin intravenously&quot;&#10;  WHEN 33361 THEN &quot;Transcatheter aortic valve replacement&quot;&#10;  WHEN 61796 THEN &quot;Stereotactic radiosurgery (simple)&quot;&#10;  WHEN 61798 THEN &quot;Stereotactic radiosurgery (complex)&quot;&#10;  WHEN 33262 THEN &quot;Removal and replacement of a pulse generator with one lead&quot;&#10;  WHEN 64568 THEN &quot;Incision for implantation of cranial nerve&quot;&#10;  WHEN 50391 THEN &quot;Other Renal Introduction (Injection/Change/Removal)&quot;&#10;  WHEN 63277 THEN &quot;Laminectomy for biopsy/excision of intraspinal neoplasm&quot;&#10;  ELSE STR([Billing Code (copy)_5292011042807881729]) // fallback: show code as text&#10;END' />
            </column>
            <column caption='Billing Code' datatype='integer' name='[billing_code]' role='dimension' type='ordinal' />
            <column caption='Discounted Cash' datatype='real' name='[discounted_cash]' role='measure' type='quantitative' />
            <column caption='Insurer Price' datatype='real' name='[insurer_price]' role='measure' type='quantitative' />
            <column-instance column='[discounted_cash]' derivation='Max' name='[max:discounted_cash:qk]' pivot='key' type='quantitative' />
            <column-instance column='[insurer_price]' derivation='Max' name='[max:insurer_price:qk]' pivot='key' type='quantitative' />
            <column caption='Metroplex' datatype='string' name='[metroplex]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1080300962865369088]' derivation='None' name='[none:Calculation_1080300962865369088:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_5292011042807595008]' derivation='None' name='[none:Calculation_5292011042807595008:nk]' pivot='key' type='nominal' />
            <column-instance column='[billing_code]' derivation='None' name='[none:billing_code:ok]' pivot='key' type='ordinal' />
            <column-instance column='[metroplex]' derivation='None' name='[none:metroplex:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_442549038454980611]' derivation='User' name='[usr:Calculation_442549038454980611:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.1lzqd641yvgrh7183uk5c18yqpxo].[max:insurer_price:qk]&quot;' />
              <groupfilter function='member' level='[:Measure Names]' member='&quot;[federated.1lzqd641yvgrh7183uk5c18yqpxo].[max:discounted_cash:qk]&quot;' />
            </groupfilter>
          </filter>
          <manual-sort column='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[:Measure Names]' direction='ASC'>
