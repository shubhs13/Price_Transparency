      <aliases enabled='yes' />
      <column caption='Billing Codes' datatype='integer' name='[Billing Code (copy)_5292011042807881729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[billing_code]' />
      </column>
      <column caption='Billing Code 5 digits' datatype='boolean' name='[Calculation_1080300962865369088]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN(STR([billing_code])) = 5' />
      </column>
      <column caption='Billing code in both metro' datatype='boolean' name='[Calculation_1080300962867023873]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [billing_code] : COUNTD([metroplex]) } = 2' />
      </column>
      <column caption='top 10 variance' datatype='real' name='[Calculation_1080300962870300674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [billing_code] : VAR([insurer_price]) }' />
      </column>
      <column caption='Top 10 expensive - Discounted Cash' datatype='string' name='[Calculation_134756151091552256]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Billing Code (copy)_5292011042807881729]&#10;  WHEN 33990 THEN &quot;Insertion of ventricular assist device&quot;&#10;  WHEN 42100 THEN &quot;Biopsy of the palate or uvula&quot;&#10;  WHEN 47135 THEN &quot;Transplantation of the liver&quot;&#10;  WHEN 33249 THEN &quot;Implantable Defibrillator Procedures&quot;&#10;  WHEN 33361 THEN &quot;Transcatheter aortic valve replacement&quot;&#10;  WHEN 90288 THEN &quot;Botulism immune globulin intravenously&quot;&#10;  WHEN 33270 THEN &quot;Insertion or replacement of a permanent subcutaneous implantable defibrillator&quot;&#10;  WHEN 64568 THEN &quot;Incision for implantation of cranial nerve&quot;&#10;  WHEN 50391 THEN &quot;Other Renal Introduction (Injection/Change/Removal)&quot;&#10;  WHEN 37227 THEN &quot;Endovascular Revascularization&quot;&#10;  ELSE STR([Billing Code (copy)_5292011042807881729]) // fallback: show code as text&#10;END' />
      </column>
      <column caption='Top 10 common procedures' datatype='string' name='[Calculation_205406370311413760]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Billing Code (copy)_5292011042807881729]&#10;  WHEN 83516 THEN &quot;Qualitative immunoassay for an analyte other than an infectious agent antibody or antigen&quot;&#10;  WHEN 83520 THEN &quot;Quantitative immunoassay for an analyte other than an infectious agent antibody or antigen&quot;&#10;  WHEN 85347 THEN &quot;Activated coagulation time (ACT) test&quot;&#10;  WHEN 86003 THEN &quot;Allergen-specific IgE; quantitative or semi-quantitative testing&quot;&#10;  WHEN 86235 THEN &quot;Extractable nuclear antigen antibody tests&quot;&#10;  WHEN 86255 THEN &quot;Qualitative or semi-quantitative immunoassay to screen for a noninfectious agent antibody using a fluorescent method&quot;&#10;  WHEN 86256 THEN &quot;Fluorescent noninfectious agent antibody titer&quot;&#10;  WHEN 86317 THEN &quot;Immunoassay for infectious agent antibody&quot;&#10;  WHEN 87798 THEN &quot;Infectious agent detection by nucleic acid&quot;&#10;  WHEN 88271 THEN &quot;Molecular cytogenetics; DNA probe&quot;&#10;  ELSE STR([Billing Code (copy)_5292011042807881729]) // fallback: show code as text&#10;END' />
      </column>
      <column caption='Null insurer price' datatype='real' name='[Calculation_228135474704105472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([insurer_price]) THEN [max_price]&#10;ELSE [insurer_price]&#10;END' />
      </column>
      <column caption='DC &lt; IP' datatype='boolean' name='[Calculation_286823007395753984]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[discounted_cash] &lt; [insurer_price]' />
      </column>
      <column caption='IQR' datatype='real' name='[Calculation_3127679576329519104]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_PERCENTILE(AVG([insurer_price]), 0.75) - WINDOW_PERCENTILE(AVG([insurer_price]), 0.25)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Median Insurer Price' datatype='real' name='[Calculation_442549038452088832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([insurer_price])' />
      </column>
      <column caption='NY higher than Austin' datatype='string' name='[Calculation_442549038452465665]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([metroplex]) = &quot;NYC&quot; AND &#10;   [Calculation_442549038452088832] &gt; LOOKUP([Calculation_442549038452088832], -1)&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Normal&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Austin higher than NY' datatype='string' name='[Calculation_442549038453518338]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([metroplex]) = &quot;Austin&quot; AND &#10;   [Calculation_442549038452088832] &gt; LOOKUP([Calculation_442549038452088832], -1)&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Normal&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='DC&lt;IP' datatype='string' name='[Calculation_442549038454980611]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([metroplex]) = &quot;NYC&quot; AND &#10;   [Calculation_442549038455279621] &lt; [Calculation_442549038455218180]&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Normal&quot;&#10;END' />
      </column>
      <column caption='Max IP' datatype='real' name='[Calculation_442549038455218180]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([insurer_price])' />
      </column>
      <column caption='Max DC' datatype='real' name='[Calculation_442549038455279621]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([discounted_cash])' />
      </column>
      <column caption='75th percentile' datatype='real' name='[Calculation_5202783475147399168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='PERCENTILE([insurer_price], 0.75)' />
      </column>
      <column caption='Top 10 expensive - insurer price' datatype='string' name='[Calculation_5292011042807595008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Billing Code (copy)_5292011042807881729]&#10;  WHEN 42100 THEN &quot;Biopsy of the palate or uvula&quot;&#10;  WHEN 33249 THEN &quot;Implantable Defibrillator Procedures&quot;&#10;  WHEN 90288 THEN &quot;Botulism immune globulin intravenously&quot;&#10;  WHEN 33361 THEN &quot;Transcatheter aortic valve replacement&quot;&#10;  WHEN 61796 THEN &quot;Stereotactic radiosurgery (simple)&quot;&#10;  WHEN 61798 THEN &quot;Stereotactic radiosurgery (complex)&quot;&#10;  WHEN 33262 THEN &quot;Removal and replacement of a pulse generator with one lead&quot;&#10;  WHEN 64568 THEN &quot;Incision for implantation of cranial nerve&quot;&#10;  WHEN 50391 THEN &quot;Other Renal Introduction (Injection/Change/Removal)&quot;&#10;  WHEN 63277 THEN &quot;Laminectomy for biopsy/excision of intraspinal neoplasm&quot;&#10;  ELSE STR([Billing Code (copy)_5292011042807881729]) // fallback: show code as text&#10;END' />
      </column>
      <column caption='Valid Insurer price ' datatype='integer' name='[Calculation_949344734381637632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([insurer_price]) AND [insurer_price] &gt; 0 THEN 1 ELSE 0 END' />
      </column>
