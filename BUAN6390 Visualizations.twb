    <worksheet name='10 common - median'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Median Insurer Price of Top 10 common procedures </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Project_Data' name='federated.1lzqd641yvgrh7183uk5c18yqpxo' />
          </datasources>
          <datasource-dependencies datasource='federated.1lzqd641yvgrh7183uk5c18yqpxo'>
            <column caption='Billing Codes' datatype='integer' name='[Billing Code (copy)_5292011042807881729]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[billing_code]' />
            </column>
            <column caption='Billing Code 5 digits' datatype='boolean' name='[Calculation_1080300962865369088]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN(STR([billing_code])) = 5' />
            </column>
            <column caption='Top 10 common procedures' datatype='string' name='[Calculation_205406370311413760]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Billing Code (copy)_5292011042807881729]&#10;  WHEN 83516 THEN &quot;Qualitative immunoassay for an analyte other than an infectious agent antibody or antigen&quot;&#10;  WHEN 83520 THEN &quot;Quantitative immunoassay for an analyte other than an infectious agent antibody or antigen&quot;&#10;  WHEN 85347 THEN &quot;Activated coagulation time (ACT) test&quot;&#10;  WHEN 86003 THEN &quot;Allergen-specific IgE; quantitative or semi-quantitative testing&quot;&#10;  WHEN 86235 THEN &quot;Extractable nuclear antigen antibody tests&quot;&#10;  WHEN 86255 THEN &quot;Qualitative or semi-quantitative immunoassay to screen for a noninfectious agent antibody using a fluorescent method&quot;&#10;  WHEN 86256 THEN &quot;Fluorescent noninfectious agent antibody titer&quot;&#10;  WHEN 86317 THEN &quot;Immunoassay for infectious agent antibody&quot;&#10;  WHEN 87798 THEN &quot;Infectious agent detection by nucleic acid&quot;&#10;  WHEN 88271 THEN &quot;Molecular cytogenetics; DNA probe&quot;&#10;  ELSE STR([Billing Code (copy)_5292011042807881729]) // fallback: show code as text&#10;END' />
            </column>
            <column caption='Median Insurer Price' datatype='real' name='[Calculation_442549038452088832]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MEDIAN([insurer_price])' />
            </column>
            <column caption='NY higher than Austin' datatype='string' name='[Calculation_442549038452465665]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF ATTR([metroplex]) = &quot;NYC&quot; AND &#10;   [Calculation_442549038452088832] &gt; LOOKUP([Calculation_442549038452088832], -1)&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Normal&quot;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Billing Code' datatype='integer' name='[billing_code]' role='dimension' type='ordinal' />
            <column caption='Insurer Price' datatype='real' name='[insurer_price]' role='measure' type='quantitative' />
            <column-instance column='[insurer_price]' derivation='Median' name='[med:insurer_price:qk]' pivot='key' type='quantitative' />
            <column caption='Metroplex' datatype='string' name='[metroplex]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1080300962865369088]' derivation='None' name='[none:Calculation_1080300962865369088:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_205406370311413760]' derivation='None' name='[none:Calculation_205406370311413760:nk]' pivot='key' type='nominal' />
            <column-instance column='[billing_code]' derivation='None' name='[none:billing_code:ok]' pivot='key' type='ordinal' />
            <column-instance column='[metroplex]' derivation='None' name='[none:metroplex:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_442549038452465665]' derivation='User' name='[usr:Calculation_442549038452465665:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Rows' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[none:Calculation_1080300962865369088:nk]'>
            <groupfilter function='member' level='[none:Calculation_1080300962865369088:nk]' member='true' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[none:billing_code:ok]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='COUNT([Billing Code (copy)_5292011042807881729])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:billing_code:ok]' user:ui-manual-selection='true' user:ui-manual-selection-all-when-empty='true' user:ui-manual-selection-is-empty='true' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[none:Calculation_205406370311413760:nk]' direction='ASC' measure-to-sort-by='[federated.1lzqd641yvgrh7183uk5c18yqpxo].[none:billing_code:ok]' shelf='rows' />
